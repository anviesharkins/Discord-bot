# Token do seu bot no Discord Developer Portal
DISCORD_TOKEN=coloque_o_token_aqui

# ID da aplicação/bot no Discord Developer Portal
DISCORD_CLIENT_ID=coloque_o_client_id_aqui

# Opcional: ID de um servidor para registrar comandos mais rápido durante testes
DISCORD_GUILD_ID=coloque_o_guild_id_aqui

# Prefixo para comandos por mensagem, exemplo: !ping
BOT_PREFIX=!
